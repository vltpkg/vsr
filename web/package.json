{
  "name": "@vltpkg/vsr-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Web UI for the vlt serverless registry (public browsing + authenticated dashboard)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
